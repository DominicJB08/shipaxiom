{
  "name": "shipaxiom",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "check": "tsc --noEmit",
    "capture": "node scripts/capture-demo.mjs",
    "workflow-video": "node scripts/create-workflow-video.mjs",
    "deploy": "wrangler deploy",
    "leads": "wrangler d1 execute shipaxiom-leads --remote --command \"SELECT id, created_at, name, email, company, package_interest, status FROM leads ORDER BY created_at DESC LIMIT 25\""
  },
  "dependencies": {
    "lucide-react": "^0.561.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260615.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "playwright": "^1.61.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "wrangler": "^4.100.0"
  }
}
